{
  "name": "printr-monorepo",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/PrintrFi/printr-mcp"
  },
  "license": "Apache-2.0",
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "bun run --filter '*' build",
    "dev": "bun run --cwd packages/mcp dev",
    "start": "bun run --cwd packages/mcp start",
    "inspect": "bun run --cwd packages/mcp inspect",
    "test": "bun run --filter '*' test",
    "test:all": "bun run --filter '*' test:all",
    "test:coverage": "bun run --filter '*' test --coverage",
    "test:e2e": "bun run --cwd packages/mcp test:e2e",
    "typecheck": "bun run --filter '*' typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "bun typecheck && bun lint && bun test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@types/bun": "latest",
    "husky": "^9.1.7",
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.9.3"
  }
}
