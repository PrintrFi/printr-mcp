{
  "name": "@printr/mcp",
  "version": "0.10.1",
  "description": "MCP server for the Printr API - enables AI agents to launch tokens across EVM chains and Solana",
  "mcpName": "io.github.PrintrFi/printr",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "printr-mcp": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": ["dist", "certs", "LICENSE"],
  "repository": {
    "type": "git",
    "url": "https://github.com/PrintrFi/printr-mcp",
    "directory": "packages/mcp"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "sh scripts/build.sh",
    "dev": "bun --hot src/index.ts",
    "start": "bun src/index.ts",
    "inspect": "bunx @modelcontextprotocol/inspector bun src/index.ts",
    "test": "bun test src/",
    "test:all": "bun test",
    "test:e2e": "bun test src/e2e.spec.ts",
    "typecheck": "bun run --cwd ../sdk build && tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@printr/sdk": "workspace:*",
    "@hono/node-server": "^1.19.9",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@solana/web3.js": "^1.98.4",
    "bs58": "^6.0.0",
    "hono": "^4.12.0",
    "ink": "^6.6.0",
    "ink-spinner": "^5.0.0",
    "neverthrow": "^8.2.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "sharp": "^0.34.5",
    "viem": "^2.46.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/qrcode": "^1.5.6",
    "react-devtools-core": "^7.0.1",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  }
}
